{
    "name": "jardissupport/dotenv",
    "description": "Advanced functions dotEnv tool for reading .env files for standard global and protected contexts",
    "type": "library",
    "license": "PolyForm-Noncommercial-1.0.0",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Jardis Core Development",
            "email": "jardisCore@headgent.dev"
        }
    ],
    "require": {
        "php": ">=8.2",
        "jardisport/dotenv": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0.4",
        "squizlabs/php_codesniffer": "^3.11.2"
    },
    "autoload": {
        "psr-4": {
            "JardisSupport\DotEnv\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisSupport\DotEnv\Tests\": "tests/"
        }
    },
    "homepage": "https://github.com/jardisSupport/dotenv",
    "support": {
        "issues": "https://github.com/jardisSupport/dotenv/issues",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "dotenv",
        "env",
        "environment",
        "loader",
        "context",
        "domain driven design",
        "jardisSupport",
        "jardisport",
        "jardis"
    ]
}

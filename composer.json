{
    "name": "jardissupport/dotenv",
    "homepage": "https://jardis.io",
    "description": "Environment file loader with cascading overrides, variable interpolation, type casting, and include directives",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Jardis Development",
            "email": "jardisDev@headgent.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "jardissupport/contract": "^1.0"
    },
    "suggest": {
        "jardissupport/secret": "For encrypted secret resolution in .env files via secret(...) syntax"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0.4",
        "squizlabs/php_codesniffer": "^3.11.2"
    },
    "autoload": {
        "psr-4": {
            "JardisSupport\\DotEnv\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisSupport\\DotEnv\\Tests\\": "tests/"
        }
    },
    "support": {
        "issues": "https://github.com/jardisSupport/dotenv/issues",
        "docs": "https://docs.jardis.io/en/support/dotenv",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "dotenv",
        "env",
        "environment",
        "environment-variables",
        "configuration",
        "loader",
        "php",
        "domain-driven-design",
        "hexagonal-architecture",
        "jardissupport",
        "jardis"
    ]
}
